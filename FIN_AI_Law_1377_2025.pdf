                                    Kansion nimi:                                    <input type="text" class="text folder-name" name="name" />
                                </label>
                            </div>
                            <div class="overlay-form-action">
                                <a href="#" class="add btn">Lisää</a>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <div class="toolbar-dialog overlay add-new-heading-dialog">
        <div class="overlay-backdrop"></div>
        <div class="overlay-window">
            <div class="overlay-content">
                <div class="overlay-header">
                    <a href="#" class="close">
                        <span class="icon icon-close"></span>
                    </a>
                    <h2>Lisää uusi väliotsikko.</h2>
                </div>
                <div class="overlay-overflow">
                    <form action="#">
                        <div class="overlay-form-inner">
                            <div class="overlay-form-input">
                                <label>
                                    Väliotsikko:                                    <input type="text" class="text new-heading" name="heading" />
                                </label>
                            </div>
                            <div class="overlay-form-action">
                                <a href="#" class="add btn">Lisää</a>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>

    <div class="toolbar-dialog overlay info-dialog">
        <div class="overlay-backdrop"></div>
        <div class="overlay-window">
            <div class="overlay-content">
                <div class="overlay-header">
                    <a href="#" class="close">
                        <span class="icon icon-close"></span>
                    </a>
                    <h2 id="info-dialog-header"></h2>
                    <span id="info-dialog-text"></span>
                    <div id="info-dialog-do-not-show-again-control" class="hidden">
                        <form action="/myedilex/bookmarks/disable-info-dialog-for-moving-documents-from-favorites">
                            <label>
                                Asia selvä. En halua nähdä tätä ilmoitusta enää.                                <input type="checkbox" id="info-dialog-do-not-show-again" value="1" />
                                <div class="overlay-form-action">
                                    <a id="info-dialog-ok" href="#" class="btn">Ok</a>
                                </div>
                            </label>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
