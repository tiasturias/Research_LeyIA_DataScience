  {
   "cell_type": "markdown",
   "id": "51a43549",
   "metadata": {},
   "source": [
    "# 18. Auditoría semántica transversal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "34fbb650",
   "metadata": {},
   "outputs": [],
   "source": [
    "semantics = []\n",
    "for name, df in [(\"q2_scores\", q2_scores),(\"q5_scores\", q5_scores),(\"q6_scores\", q6_scores),(\"country_q_profile_long\", profile_long),(\"country_model_contributions\", contrib),(\"country_cluster_profile\", cluster_profile)]:\n",
    "    if df.empty:\n",
    "        continue\n",
    "    row = {\"archivo\": name}\n",
    "    for col in [\"independent_prediction\",\"causal_claim\",\"holdout_used\"]:\n",
    "        if col in df.columns:\n",
    "            row[col + \"_false_rate\"] = (df[col].fillna(False).astype(bool) == False).mean()\n",
