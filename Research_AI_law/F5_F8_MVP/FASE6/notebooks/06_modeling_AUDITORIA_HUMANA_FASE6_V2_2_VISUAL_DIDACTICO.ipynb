    "\n",
    "def read_csv_safe(path):\n",
    "    path = Path(path)\n",
    "    if not path.exists():\n",
    "        display(Markdown(f\"**No encontrado:** `{path}`\"))\n",
    "        return pd.DataFrame()\n",
    "    return pd.read_csv(path)\n",
    "\n",
    "def read_json_safe(path):\n",
    "    path = Path(path)\n",
    "    if not path.exists():\n",
    "        display(Markdown(f\"**No encontrado:** `{path}`\"))\n",
    "        return {}\n",
    "    return json.loads(path.read_text(encoding=\"utf-8\"))\n",
    "\n",
    "def tr(v):\n",
    "    return VARIABLE_TRANSLATOR.get(str(v), str(v))\n",
    "\n",
    "def tr_role(v):\n",
    "    return ROLE_TRANSLATOR.get(str(v), str(v))\n",
    "\n",
    "def short(s, n=75):\n",
    "    s = str(s)\n",
    "    return s if len(s) <= n else s[:n-3] + \"...\"\n",
    "\n",
    "def context(title, q=None, level=\"\", x_axis=\"\", y_axis=\"\", variables=None, countries=\"\", message=\"\", caution=\"\"):\n",
    "    qline = \"\"\n",
    "    if q in QUESTION_GUIDE:\n",
    "        qline = f\"**Pregunta {q}:** {QUESTION_GUIDE[q]['plain']}\\n\\n\"\n",
    "    varline = \"\"\n",
    "    if variables:\n",
    "        varline = \"**Variables involucradas:**\\n\" + \"\\n\".join([f\"- `{v}` → {tr(v)}\" for v in sorted(set(map(str, variables)))]) + \"\\n\\n\"\n",
    "    text = f\"### {title}\\n\\n{qline}**Nivel del gráfico:** {level}\\n\\n**Eje X:** {x_axis}\\n\\n**Eje Y:** {y_axis}\\n\\n\"\n",
    "    text += varline\n",
    "    if countries:\n",
    "        text += f\"**Países involucrados:** {countries}\\n\\n\"\n",
    "    text += f\"**Mensaje que entrega:** {message}\\n\\n**Cautela:** {caution}\"\n",
    "    display(Markdown(text))\n",
    "\n",
    "def show_existing_image(rel_path, title, q=None, note=\"\", width=1100):\n",
    "    context(\n",
    "        title=title, q=q, level=\"Figura existente generada por Fase 6.2\",\n",
    "        x_axis=\"Según la figura; se interpreta en la nota\",\n",
    "        y_axis=\"Según la figura; se interpreta en la nota\",\n",
    "        message=note or \"Visualización existente de los outputs auditados.\",\n",
    "        caution=\"Este notebook solo muestra la imagen; no la regenera ni la sobrescribe.\"\n",
    "    )\n",
    "    path = FIG / rel_path\n",
    "    if path.exists():\n",
    "        display(Image(filename=str(path), width=width))\n",
    "    else:\n",
    "        display(Markdown(f\"**Figura no encontrada:** `{path}`\"))\n",
    "\n",
    "def horizontal_bar(df, y, x, title, xlabel, q=None, level=\"\", variables=None, countries=\"\", message=\"\", caution=\"\", highlight_col=None):\n",
    "    context(title, q=q, level=level, x_axis=xlabel, y_axis=y, variables=variables, countries=countries, message=message, caution=caution)\n",
    "    if df.empty or y not in df.columns or x not in df.columns:\n",
    "        display(Markdown(\"**Sin datos suficientes para construir este gráfico.**\"))\n",
    "        return\n",
    "    d = df.dropna(subset=[x]).copy()\n",
    "    if d.empty:\n",
    "        display(Markdown(\"**No hay valores no nulos para graficar.**\"))\n",
    "        return\n",
    "    fig, ax = plt.subplots(figsize=(12, max(4.8, 0.34 * len(d))))\n",
    "    labels = d[y].astype(str).map(lambda s: short(s, 95))\n",
    "    vals = pd.to_numeric(d[x], errors=\"coerce\")\n",
    "    if highlight_col and highlight_col in d.columns:\n",
    "        colors = []\n",
    "        for iso in d[highlight_col].astype(str):\n",
    "            if iso == \"CHL\":\n",
    "                colors.append(\"tab:red\")\n",
    "            elif iso == \"SGP\":\n",
    "                colors.append(\"tab:green\")\n",
    "            elif iso in {\"USA\",\"CHN\",\"EST\",\"IRL\",\"ARE\",\"KOR\",\"BRA\",\"URY\"}:\n",
    "                colors.append(\"tab:blue\")\n",
    "            else:\n",
    "                colors.append(\"lightgray\")\n",
    "        ax.barh(labels, vals, color=colors)\n",
    "    else:\n",
    "        ax.barh(labels, vals)\n",
    "    \"    q4_info = row.get(\\\"Q4_regulatory_profile\\\", None)\\n\",\n",
    "    \"    display_title = title + (f\\\"\\\\\\\\nQ4: {q4_info}\\\" if pd.notna(q4_info) else \\\"\\\")\\n\",\n",
    "    \"    ax.set_title(display_title, fontsize=9)\\n\",\n",
    "    ax.set_xlabel(xlabel)\n",
    "    ax.grid(axis=\"x\", alpha=0.25)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "def pie_counts(series, title, q=None, level=\"\", message=\"\", caution=\"\"):\n",
    "    context(title, q=q, level=level, x_axis=\"No aplica: proporciones\", y_axis=\"Categorías\", message=message, caution=caution)\n",
    "    counts = series.fillna(\"Sin dato\").value_counts()\n",
    "    fig, ax = plt.subplots(figsize=(7, 7))\n",
    "    ax.pie(counts.values, labels=counts.index, autopct=\"%1.0f%%\", startangle=90)\n",
    "    ax.set_title(title)\n",
    "    plt.show()\n",
    "\n",
    "def plot_coefficients(df, q):\n",
    "    if df.empty or \"estimate\" not in df.columns or \"term\" not in df.columns:\n",
    "        display(Markdown(\"**No hay datos suficientes para coeficientes.**\"))\n",
    "        return\n",
    "    d = df.copy()\n",
    "    if \"analysis_role\" in d.columns:\n",
    "        primary = d[d[\"analysis_role\"].astype(str).str.contains(\"primary\", case=False, na=False)]\n",
    "        if len(primary) > 0:\n",
    "            d = primary.copy()\n",
    "    d = d.dropna(subset=[\"estimate\"])\n",
    "    if d.empty:\n",
    "        return\n",
    "    d[\"predictor_comun\"] = d[\"term\"].map(tr)\n",
    "    d[\"outcome_comun\"] = d[\"outcome\"].map(tr)\n",
    "    d[\"label\"] = d[\"outcome_comun\"].map(lambda s: short(s, 42)) + \" | \" + d[\"predictor_comun\"].map(lambda s: short(s, 36))\n",
    "    if \"n_effective\" in d.columns:\n",
    "        d[\"label\"] = d[\"label\"] + \" | n=\" + d[\"n_effective\"].astype(str)\n",
    "    variables = list(d[\"term\"].dropna().astype(str).unique()) + list(d[\"outcome\"].dropna().astype(str).unique())\n",
    "    context(\n",
    "        f\"{QUESTION_GUIDE[q]['title']} — coeficientes de asociación ajustada\",\n",
    "        q=q,\n",
    "        level=\"Toda la submuestra efectiva disponible para cada outcome; no es un país individual\",\n",
    "        x_axis=\"Coeficiente estimado del predictor regulatorio\",\n",
    "        y_axis=\"Outcome en lenguaje común | predictor en lenguaje común | n efectivo\",\n",
    "        variables=variables,\n",
    "        countries=\"Países con datos completos para cada outcome y predictor. El n efectivo aparece en cada barra.\",\n",
    "        message=\"Muestra si la asociación entre regulación y resultado es positiva o negativa.\",\n",
    "        caution=\"No muestra qué país es mejor. No prueba causalidad. Para país-por-país se usan rankings, heatmaps y country cards.\"\n",
    "    )\n",
    "    d = d.sort_values(\"estimate\", ascending=True)\n",
    "    fig, ax = plt.subplots(figsize=(13, max(5, 0.42 * len(d))))\n",
    "    colors = [\"tab:green\" if v >= 0 else \"tab:red\" for v in d[\"estimate\"]]\n",
    "    ax.barh(d[\"label\"], d[\"estimate\"], color=colors, alpha=0.85)\n",
    "    ax.axvline(0, color=\"black\", linewidth=1)\n",
    "    ax.set_title(f\"{QUESTION_GUIDE[q]['title']} — asociaciones ajustadas\")\n",
    "    ax.set_xlabel(\"Coeficiente estimado\")\n",
    "    ax.grid(axis=\"x\", alpha=0.25)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "def plot_effect_significance(df, q):\n",
    "    if df.empty or \"estimate\" not in df.columns or \"p_value\" not in df.columns:\n",
    "        return\n",
    "    d = df.copy()\n",
    "    if \"analysis_role\" in d.columns:\n",
    "        primary = d[d[\"analysis_role\"].astype(str).str.contains(\"primary\", case=False, na=False)]\n",
    "        if len(primary) > 0:\n",
    "            d = primary.copy()\n",
    "    d = d.dropna(subset=[\"estimate\", \"p_value\"])\n",
    "    if d.empty:\n",
    "        return\n",
    "    d[\"neglog10_p\"] = -np.log10(d[\"p_value\"].clip(lower=1e-300))\n",
    "    variables = list(d.get(\"term\", pd.Series()).dropna().astype(str).unique()) + list(d.get(\"outcome\", pd.Series()).dropna().astype(str).unique())\n",
    "    context(\n",
    "        f\"{QUESTION_GUIDE[q]['title']} — magnitud y evidencia estadística\",\n",
    "        q=q,\n",
    "        level=\"Modelos outcome × predictor\",\n",
    "        x_axis=\"Coeficiente estimado\",\n",
    "        y_axis=\"-log10(p-value): más alto = menor p-value\",\n",
    "        variables=variables,\n",
    "        countries=\"Países con datos disponibles para cada modelo.\",\n",
    "        message=\"Ayuda a separar asociaciones grandes y más claras de asociaciones débiles o inciertas.\",\n",
    "        caution=\"Un p-value bajo no prueba causalidad ni sustituye Fase 7.\"\n",
    "    )\n",
    "    fig, ax = plt.subplots(figsize=(10, 6))\n",
    "    ax.scatter(d[\"estimate\"], d[\"neglog10_p\"], alpha=0.75)\n",
    "    ax.axvline(0, color=\"black\", linewidth=1)\n",
    "    ax.axhline(-np.log10(0.05), color=\"gray\", linestyle=\"--\", linewidth=1)\n",
    "    for _, r in d.iterrows():\n",
    "        ax.text(r[\"estimate\"], r[\"neglog10_p\"], f\"{tr(r.get('term',''))[:18]}\\\\n{tr(r.get('outcome',''))[:18]}\", fontsize=7)\n",
    "    ax.set_title(f\"{QUESTION_GUIDE[q]['title']} — efecto vs p-value\")\n",
    "    ax.set_xlabel(\"Coeficiente estimado\")\n",
    "    ax.set_ylabel(\"-log10(p-value)\")\n",
    "    ax.grid(alpha=0.25)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "def plot_n_effective(df, q):\n",
    "    if df.empty or \"n_effective\" not in df.columns or \"outcome\" not in df.columns:\n",
    "        return\n",
    "    g = df.groupby(\"outcome\")[\"n_effective\"].min().sort_values().reset_index()\n",
    "    g[\"outcome_comun\"] = g[\"outcome\"].map(tr)\n",
    "    horizontal_bar(\n",
    "        g,\n",
    "        y=\"outcome_comun\",\n",
    "        x=\"n_effective\",\n",
    "        title=f\"{QUESTION_GUIDE[q]['title']} — países efectivos por outcome\",\n",
    "        q=q,\n",
    "        level=\"Submuestra efectiva por outcome\",\n",
    "        variables=list(g[\"outcome\"].unique()),\n",
    "        countries=\"No todos los 43 países entran en cada modelo; se excluyen datos faltantes.\",\n",
    "        xlabel=\"Número de países efectivamente usados\",\n",
    "        message=\"Muestra cuántos países sostienen cada resultado.\",\n",
    "        caution=\"Con n efectivo bajo, la lectura debe ser exploratoria aunque el coeficiente parezca grande.\"\n",
    "    )\n",
    "\n",
    "def plot_country_profile(wide, iso3, title):\n",
    "    if wide.empty or \"iso3\" not in wide.columns:\n",
    "        display(Markdown(\"**No hay perfil wide.**\"))\n",
    "        return\n",
    "    row = wide[wide[\"iso3\"].eq(iso3)]\n",
    "    if row.empty:\n",
    "        display(Markdown(f\"**País no encontrado:** `{iso3}`\"))\n",
    "        return\n",
    row = row.iloc[0]\n",
    "    q_cols = [x for x in [\"Q1_percentile\",\"Q2_percentile\",\"Q3_percentile\",\"Q5_percentile\",\"Q6_percentile\"] if x in wide.columns]\n",
    "    vals = [row[x] for x in q_cols]\n",
    "    labels = [x.replace(\"_percentile\",\"\") for x in q_cols]\n",
    "    context(\n",
    "        title,\n",
    "        level=\"País individual comparado contra la muestra\",\n",
    "        x_axis=\"Preguntas Q1/Q2/Q3/Q5/Q6\",\n",
    "        y_axis=\"Percentil descriptivo entre 0 y 1\",\n",
    "        countries=f\"País focal: {iso3} — {row.get('country_name','')}\",\n",
    "        message=\"Resume fortalezas y debilidades del país por dimensión.\",\n",
    "        caution=\"No es un índice causal ni predice desempeño futuro.\"\n",
    "    )\n",
    "    colors = [\"tab:green\" if pd.notna(v) and v >= 0.75 else \"tab:red\" if pd.notna(v) and v <= 0.25 else \"tab:blue\" for v in vals]\n",
    "    fig, ax = plt.subplots(figsize=(8, 5))\n",
    "    ax.bar(labels, vals, color=colors, alpha=0.86)\n",
    "    ax.set_ylim(0, 1)\n",
    "    ax.axhline(0.75, color=\"gray\", linestyle=\"--\", linewidth=1)\n",
    "    ax.axhline(0.25, color=\"gray\", linestyle=\"--\", linewidth=1)\n",
    "    for i, v in enumerate(vals):\n",
    "        if pd.notna(v):\n",
    "            ax.text(i, v + 0.025, f\"{v:.2f}\", ha=\"center\")\n",
    "    ax.set_title(title)\n",
    "    ax.set_ylabel(\"Percentil descriptivo\")\n",
    "    ax.grid(axis=\"y\", alpha=0.25)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n"
   ]
  },
