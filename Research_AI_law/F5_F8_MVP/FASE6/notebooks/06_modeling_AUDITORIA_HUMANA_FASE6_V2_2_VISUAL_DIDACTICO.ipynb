   "source": [
    "if not contrib.empty and {\"iso3\",\"standardized_contribution\",\"term\",\"outcome\",\"question_id\"}.issubset(contrib.columns):\n",
    "    for iso in [\"SGP\",\"CHL\",\"EST\",\"IRL\",\"ARE\",\"KOR\",\"USA\",\"CHN\",\"BRA\",\"URY\"]:\n",
    "        sub = contrib[contrib[\"iso3\"].eq(iso)].copy()\n",
    "        if sub.empty:\n",
    "            continue\n",
    "        if \"abs_contribution\" not in sub.columns:\n",
    "            sub[\"abs_contribution\"] = sub[\"standardized_contribution\"].abs()\n",
    "        top = sub.sort_values(\"abs_contribution\", ascending=True).tail(12)\n",
    "        top[\"label\"] = top[\"question_id\"].astype(str) + \" | \" + top[\"term\"].map(tr).map(lambda x: short(x,34)) + \" | \" + top[\"outcome\"].map(tr).map(lambda x: short(x,34))\n",
    "        horizontal_bar(top, y=\"label\", x=\"standardized_contribution\", title=f\"{iso} — principales drivers descriptivos\", level=\"País individual × outcome × predictor\", countries=f\"País focal: {iso}\", variables=list(top[\"term\"].astype(str).unique()) + list(top[\"outcome\"].astype(str).unique()), xlabel=\"Contribución estandarizada\", message=\"Muestra qué predictores y outcomes aportan más al posicionamiento descriptivo.\", caution=\"No significa que esos drivers causen el resultado.\")"
