   "source": [
    "if not rank_outcome.empty and \"question_id\" in rank_outcome.columns:\n",
    "    counts = rank_outcome.groupby(\"question_id\")[\"outcome\"].nunique().reset_index(name=\"n_outcomes\")\n",
    "    horizontal_bar(counts.sort_values(\"n_outcomes\"), y=\"question_id\", x=\"n_outcomes\", title=\"Cantidad de indicadores rankeados por Q\", level=\"Resumen de rankings país-por-país\", xlabel=\"Número de outcomes\", message=\"Muestra cuántas variables concretas alimentan cada pregunta.\", caution=\"Más variables no significa más importancia política.\")\n",
    "    for q in [\"Q1\",\"Q2\",\"Q3\",\"Q5\",\"Q6\"]:\n",
    "        qdf = rank_outcome[rank_outcome[\"question_id\"].eq(q)].copy()\n",
    "        if qdf.empty:\n",
    "            continue\n",
    "        outcome = qdf.groupby(\"outcome\")[\"iso3\"].nunique().sort_values(ascending=False).index[0]\n",
    "        sub = qdf[qdf[\"outcome\"].eq(outcome)].copy()\n",
    "        top = sub.nsmallest(8, \"rank_desc\")\n",
    "        bottom = sub.nsmallest(8, \"rank_asc\")\n",
    "        plot_df = pd.concat([top,bottom]).drop_duplicates(\"iso3\").sort_values(\"percentile\")\n",
    "        plot_df[\"label\"] = plot_df[\"iso3\"] + \" — \" + plot_df[\"country_name\"]\n",
    "        horizontal_bar(plot_df, y=\"label\", x=\"percentile\", title=f\"{QUESTION_GUIDE[q]['title']} — top/bottom del indicador: {tr(outcome)}\", q=q, level=\"Países rankeados en un outcome específico\", variables=[outcome], countries=\"Top 8 y bottom 8 del indicador seleccionado; CHL/SGP destacados si aparecen.\", xlabel=\"Percentil descriptivo\", message=\"Muestra extremos del ranking para un indicador representativo.\", caution=\"Ranking descriptivo por outcome; no causalidad.\", highlight_col=\"iso3\")"
