    "    horizontal_bar(focus, y=\"label\", x=\"gap_vs_singapore\", title=\"Brecha promedio frente a Singapur\", level=\"Países comparados contra Singapur\", countries=\"Países con residuals disponibles; benchmarks destacados.\", xlabel=\"Valor del país menos valor de Singapur\", message=\"Identifica qué países están más lejos o más cerca de Singapur.\", caution=\"No significa que Singapur sea el único modelo correcto ni explica causalidad.\", highlight_col=\"iso3\")"
