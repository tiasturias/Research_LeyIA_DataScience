   "source": [
    "F5_BUNDLE = ROOT / \"FASE5\" / \"outputs\" / \"phase6_ready\"\n",
    "fm_vars = read_csv_safe(F5_BUNDLE / \"phase6_feature_matrix.csv\")\n",
    "if not fm_vars.empty:\n",
    "    exclude = {\"source_list\",\"included_in_matrix\",\"included_in_dense_candidate\",\"inclusion_notes\",\"pct_variables_available\",\"n_variables_available\",\"n_sources_present\",\"binding_variables_used\",\"non_binding_variables_used\",\"hybrid_variables_used\"}\n",
    "    def categorize(col):\n",
    "        if col in exclude: return None\n",
    "        if col.endswith(\"_z\"): return None\n",
    "        if col.endswith(\"_log\") and col[:-4] in fm_vars.columns: return None\n",
    "        if \"tr_\" in col: return \"Techieray — Regulación IA detallada\"\n",
    "        if col.startswith(\"oxford_\"): return \"Oxford Insights — Ecosistema IA\"\n",
    "        if col.startswith(\"wipo_\"): return \"WIPO GII — Innovacion\"\n",
    "        if col.startswith(\"wb_\"): return \"Banco Mundial — Controles\"\n",
    "        if col.startswith(\"ms_\"): return \"Microsoft — Difusion IA\"\n",
    "        if col.startswith(\"oecd_\"): return \"OECD — Adopcion/Gobierno digital\"\n",
    "        if col.startswith(\"anthropic_\"): return \"Anthropic — Uso de IA\"\n",
    "        if col.startswith(\"stanford_\"): return \"Stanford HAI — Publicaciones\"\n",
    "        if col in {\"n_binding\",\"n_non_binding\",\"n_hybrid\",\"regulatory_intensity\",\"n_regulatory_mechanisms\"}: return \"Corpus legal-IA — Predictores\"\n",
    "        if col in {\"iso3\",\"country_name_canonical\",\"region\",\"income_group\",\"entity_type\"}: return \"Metadato\"\n",
    "        return None\n",
    "    var_rows = []\n",
    "    for c in sorted(fm_vars.columns):\n",
    "        cat = categorize(c)\n",
    "        if cat is None: continue\n",
    "        na = fm_vars[c].isna().sum()\n",
    "        na_pct = round(na / len(fm_vars) * 100, 1)\n",
    "        translated = tr(c)\n",
    "        if translated == c and \"_log\" in c:\n",
    "            translated = tr(c.replace(\"_log\",\"\")) + \" (escala log)\"\n",
    "        var_rows.append({\"variable\": c, \"categoria\": cat, \"descripcion\": translated, \"faltante_%\": na_pct})\n",
    "    var_df = pd.DataFrame(var_rows)\n",
    "    total = len(fm_vars.columns)\n",
    "    display(Markdown(f\"### Feature matrix Fase 5: 43 paises x ~46 variables base ({total} columnas totales con transformaciones _z y _log)\"))\n",
    "    display(Markdown(f\"**{len(var_df)} variables base documentadas.** Las variantes _z (z-score estandarizado) y _log (logaritmica) se excluyen para claridad.\"))\n",
    "    cat_counts = var_df[\"categoria\"].value_counts()\n",
    "    fig, ax = plt.subplots(figsize=(12, 5.5))\n",
    "    colors_list = [\"#2c3e50\",\"#e74c3c\",\"#3498db\",\"#2ecc71\",\"#f39c12\",\"#9b59b6\",\"#1abc9c\",\"#e67e22\",\"#95a5a6\"][:len(cat_counts)]\n",
    "    ax.bar(cat_counts.index, cat_counts.values, color=colors_list)\n",
    "    ax.set_title(f\"Distribucion de variables por fuente de datos ({len(var_df)} vars base)\")\n",
    "    ax.set_ylabel(\"Cantidad\")\n",
    "    ax.tick_params(axis=\"x\", rotation=40, labelsize=8)\n",
    "    ax.grid(axis=\"y\", alpha=0.25)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    display(var_df.head(80))\n",
    "else:\n",
    "    display(Markdown(\"**Feature matrix no encontrada.**\"))\n",
    "\n"
   ]
