    "\n",
    "# Porcentajes\n",
    "group_pct = (group_dist / len(df_ade) * 100).round(1)\n",
    "print(\"\\nPorcentajes:\")\n",
    "for group, pct in group_pct.items():\n",
    "    print(f\"  {group}: {pct}%\")"
   ]
